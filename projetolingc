// PARQUINHO PRINCIPAL: ONDE TUDO ACONTECE
// ==============================================================================

int main() {
    printf("====== INICIANDO MISSAO DETETIVE ======\n\n");

    // --- TESTANDO A ORDENACAO ---
    int bagunca1[] = {42, 7, 15, 3, 99};
    int bagunca2[] = {42, 7, 15, 3, 99};
    int bagunca3[] = {42, 7, 15, 3, 99};
    int bagunca4[] = {42, 7, 15, 3, 99};
    int bagunca5[] = {42, 7, 15, 3, 99};
    int tamanho = 5;

    printf("--- TESTANDO JOGOS DE ARRUMAR ---\n");
    mostrar_brinquedos(bagunca1, tamanho, "Como estava antes");
    
    bubble_sort(bagunca1, tamanho);
    mostrar_brinquedos(bagunca1, tamanho, "Depois do Bubble Sort");

    selection_sort(bagunca2, tamanho);
    mostrar_brinquedos(bagunca2, tamanho, "Depois do Selection Sort");

    insertion_sort(bagunca3, tamanho);
    mostrar_brinquedos(bagunca3, tamanho, "Depois do Insertion Sort");

    merge_sort(bagunca4, 0, tamanho - 1); // Passamos o inicio (0) e o fim (4) [cite: 888, 890, 896]
    mostrar_brinquedos(bagunca4, tamanho, "Depois do Merge Sort");

    quick_sort(bagunca5, 0, tamanho - 1);
    mostrar_brinquedos(bagunca5, tamanho, "Depois do Quick Sort");


    // --- TESTANDO A ARVORE BINARIA ---
    printf("\n--- TESTANDO A ARVORE MAGICA ---\n");
    struct NoArvore* minha_arvore = NULL;
    minha_arvore = inserir_na_arvore(minha_arvore, 50); // A raiz da árvore
    inserir_na_arvore(minha_arvore, 30); // Vai pra esquerda
    inserir_na_arvore(minha_arvore, 70); // Vai pra direita
    inserir_na_arvore(minha_arvore, 20); // Esquerda da esquerda
    
    buscar_na_arvore(minha_arvore, 70);
    buscar_na_arvore(minha_arvore, 99); // Esse nao existe lá!


    // --- TESTANDO O MAPA (GRAFO) ---
    printf("\n--- TESTANDO O MAPA DE AMIGOS (GRAFOS) ---\n");
    // 0: Ana, 1: Bruno, 2: Carlos, 3: Dani
    // 1 significa amizade!
    int matriz_amigos[4][4] = {
        {0, 1, 0, 1}, // Ana é amiga do Bruno e da Dani
        {1, 0, 1, 0}, // Bruno é amigo da Ana e do Carlos
        {0, 1, 0, 0}, // Carlos só é amigo do Bruno
        {1, 0, 0, 0}  // Dani só é amiga da Ana
    };

    printf("Verificando os arquivos do detetive...\n");
    if(matriz_amigos[1][2] == 1) {
        printf(" -> Confirmado: A crianca 1 (Bruno) eh amiga da crianca 2 (Carlos)!\n");
    }
    if(matriz_amigos[2][3] == 0) {
        printf(" -> Confirmado: A crianca 2 (Carlos) ainda NAO conhece a crianca 3 (Dani).\n");
    }

    printf("\n====== MISSAO CONCLUIDA! ======\n");
    return 0;
}
