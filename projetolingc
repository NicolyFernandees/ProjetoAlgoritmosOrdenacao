#include <stdio.h>
#include <stdlib.h>

// ==============================================================================
// FERRAMENTAS DO DETETIVE
// ==============================================================================

// Ferramenta para trocar dois brinquedos de lugar [cite: 477, 478]
void trocar(int *x, int *y) {
    int aux = *x;
    *x = *y;
    *y = aux;
}

// Ferramenta para mostrar os brinquedos na tela
void mostrar_brinquedos(int A[], int tamanho, char* nome_da_missao) {
    printf("%s: ", nome_da_missao);
    for(int i = 0; i < tamanho; i++) {
        printf("%d ", A[i]);
    }
    printf("\n");
}

// ==============================================================================
// MISSÃO 1: OS JOGOS DE ARRUMAR (ORDENAÇÃO) 
// ==============================================================================

// 1. Bubble Sort: O brinquedo maior flutua para o final [cite: 836, 838, 839, 840, 841]
void bubble_sort(int A[], int n) {
    for(int i = 1; i <= n; i++) {
        for(int j = 1; j < n; j++) {
            if(A[j-1] > A[j]) {
                trocar(&A[j-1], &A[j]);
            }
        }
    }
}

// 2. Selection Sort: Procura o menor e coloca no começo [cite: 1462, 1464, 1466, 1468]
void selection_sort(int A[], int n) {
    for(int i = 0; i < n - 1; i++) {
        int posmenor = i;
        for(int j = i + 1; j < n; j++) {
            if(A[j] < A[posmenor]) {
                posmenor = j;
            }
        }
        if(posmenor != i) {
            trocar(&A[posmenor], &A[i]);
        }
    }
}

// 3. Insertion Sort: Pega um de cada vez e insere no lugar certo [cite: 1439, 1440, 1443, 1445, 1449]
void insertion_sort(int A[], int n) {
    int chave, i;
    for(int j = 1; j < n; j++) {
        chave = A[j];
        i = j - 1;
        while(i > -1 && A[i] > chave) {
            A[i+1] = A[i];
            i--;
        }
        A[i+1] = chave;
    }
}

// 4. Merge Sort (A Mágica da Divisão)
// Parte A: Junta as metades [cite: 1518, 1519, 1520, 1528]
void merge(int A[], int p, int q, int r) {
    int n1 = q - p + 1;
    int n2 = r - q;
    int L[n1], R[n2];
    
    for(int i = 0; i < n1; i++) L[i] = A[p + i];
    for(int i = 0; i < n2; i++) R[i] = A[q + i + 1];
    
    int i = 0, j = 0;
    for(int k = p; k <= r; k++) {
        if(i < n1 && (j >= n2 || L[i] <= R[j])) {
            A[k] = L[i];
            i++;
        } else {
            A[k] = R[j];
            j++;
        }
    }
}
// Parte B: Corta no meio [cite: 1500, 1501, 1502, 1503, 1504, 1505]
void merge_sort(int A[], int p, int r) {
    if(p < r) {
        int q = (p + r) / 2;
        merge_sort(A, p, q);
        merge_sort(A, q + 1, r);
        merge(A, p, q, r);
    }
}

// 5. Quick Sort (O Capitão Pivô)
// Parte A: Arruma em volta do Capitão [cite: 1226, 1228, 1230, 1234, 1235, 1236]
int partition(int A[], int p, int r) {
    int pivo = A[r];
    int i = p - 1;
    for(int j = p; j < r; j++) {
        if(A[j] <= pivo) {
            i++;
            trocar(&A[i], &A[j]);
        }
    }
    trocar(&A[i + 1], &A[r]);
    return i + 1;
}
// Parte B: Chama a missão [cite: 1207, 1209, 1211, 1213]
void quick_sort(int A[], int p, int r) {
    if(p < r) {
        int q = partition(A, p, r);
        quick_sort(A, p, q - 1);
        quick_sort(A, q + 1, r);
    }
}

// ==============================================================================
// MISSÃO 2: A ÁRVORE MÁGICA DE BUSCA (ESTRUTURA DE DADOS)
// ==============================================================================

// Como é o galho da nossa árvore
struct NoArvore {
    int brinquedo;
    struct NoArvore* esquerda; // Menores vêm pra cá
    struct NoArvore* direita;  // Maiores vêm pra cá
};

// Semente para criar um galho novo
struct NoArvore* plantar_galho(int valor) {
    struct NoArvore* novo = (struct NoArvore*)malloc(sizeof(struct NoArvore));
    novo->brinquedo = valor;
    novo->esquerda = NULL;
    novo->direita = NULL;
    return novo;
}

// Colocando o brinquedo na árvore
struct NoArvore* inserir_na_arvore(struct NoArvore* raiz, int valor) {
    if (raiz == NULL) return plantar_galho(valor); // Achou um buraco vazio!
    
    if (valor < raiz->brinquedo) {
        raiz->esquerda = inserir_na_arvore(raiz->esquerda, valor);
    } else if (valor > raiz->brinquedo) {
        raiz->direita = inserir_na_arvore(raiz->direita, valor);
    }
    return raiz;
}

// O jogo de achar rápido na árvore!
void buscar_na_arvore(struct NoArvore* raiz, int procurado) {
    if (raiz == NULL) {
        printf(" -> Puxa, nao achei o brinquedo %d na arvore.\n", procurado);
        return;
    }
    if (raiz->brinquedo == procurado) {
        printf(" -> OBA! Achei o brinquedo %d pendurado na arvore!\n", procurado);
        return;
    }
    // O truque: decidir para qual lado ir!
    if (procurado < raiz->brinquedo) {
        buscar_na_arvore(raiz->esquerda, procurado);
    } else {
        buscar_na_arvore(raiz->direita, procurado);
    }
}

